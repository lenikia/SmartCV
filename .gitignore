cat > .gitignore << 'EOF'
# Python environments
venv/
.venv/
env/

# Python cache
__pycache__/
*.pyc
*.pyo

# Environment variables
.env

# Database files
*.db
*.sqlite3

# macOS
.DS_Store
**/.DS_Store

# Uploads
backend/uploads/

# Frontend
frontend/node_modules/
frontend/dist/

# IDE
.vscode/
.idea/
EOF